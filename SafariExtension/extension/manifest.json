{
  "manifest_version": 3,
  "name": "GestureScroll",
  "version": "1.0",
  "description": "손동작으로 웹페이지를 스크롤/넘김 — 카메라로 손을 인식합니다 (완전 온디바이스).",
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["gesture.js", "content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["engine.mjs", "lib/*", "wasm/*", "model/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GestureScroll"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
